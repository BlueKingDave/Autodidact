{
  "name": "@autodidact/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "node --watch --env-file=../../.env dist/main.js",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@autodidact/db": "workspace:*",
    "@autodidact/observability": "workspace:*",
    "@autodidact/providers": "workspace:*",
    "@autodidact/schemas": "workspace:*",
    "@autodidact/types": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@autodidact/config": "workspace:*",
    "@nestjs/testing": "^10.4.0",
    "@testcontainers/postgresql": "^10.13.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-orm": "^0.38.0",
    "pg": "^8.13.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.13.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
