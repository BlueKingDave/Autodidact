    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "drizzle-orm": "^0.33.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@autodidact/config": "workspace:*",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.24.0",
    "typescript": "^5.5.4"
  }
