{
  "name": "autodidact",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "setup": "./scripts/setup.sh",
    "dev": "dotenv -e .env.dev -- ./scripts/dev.sh",
    "mobile": "./scripts/mobile.sh",
    "stop": "./scripts/stop.sh",
    "build": "turbo run build",
    "test": "./scripts/test.sh",
    "typecheck": "./scripts/typecheck.sh",
    "lint": "./scripts/lint.sh",
    "clean": "turbo run clean",
    "migrate:dev": "dotenv -e .env.dev -- ./scripts/migrate.sh",
    "migrate:prod": "dotenv -e .env.prod -- ./scripts/migrate.sh",
    "db:reset:dev": "dotenv -e .env.dev -- ./scripts/db-reset.sh",
    "db:studio:dev": "dotenv -e .env.dev -- ./scripts/db-studio.sh",
    "db:studio:prod": "dotenv -e .env.prod -- ./scripts/db-studio.sh",
    "db:generate:dev": "dotenv -e .env.dev -- ./scripts/gen-migration.sh"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.3"
}
