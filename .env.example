# =============================================================================
# AUTODIDACT — ENVIRONMENT VARIABLES
# Copy this file to .env.dev (pnpm setup does this automatically)
# =============================================================================


# ── LOCAL DATABASE + SUPABASE ────────────────────────────────────────────────
# Local dev: Docker Postgres — leave as-is, pnpm dev starts it automatically.
# WSL2 can't reach the Supabase direct host (IPv6 only) — use the
# transaction-mode pooler (IPv4, port 6543) for DATABASE_URL in that case.

DATABASE_URL=postgresql://postgres:password@localhost:5432/autodidact
# Production / WSL2 pooler example:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres

# Optional: direct connection for environments with IPv6 (cloud, native Linux)
DATABASE_URL_DIRECT=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

SUPABASE_URL=https://[ref].supabase.co

# Dashboard → Project Settings → API → Project API Keys
SUPABASE_PUBLISHABLE_KEY=
# Secret key — server-side admin client (packages/db) only; never expose to clients
SUPABASE_SECRET_KEY=


# ── AI PROVIDERS ──────────────────────────────────────────────────────────────
# OPENAI_API_KEY is required. ANTHROPIC_API_KEY is optional (only if switching LLM_PROVIDER).

OPENAI_API_KEY=
ANTHROPIC_API_KEY=


# ── REDIS ─────────────────────────────────────────────────────────────────────
# Local dev: leave as-is (Docker handles it via pnpm dev)
# Production: update to redis://<MEMORYSTORE_IP>:6379 after Terraform apply

REDIS_URL=redis://localhost:6379


# ── GOOGLE CLOUD PLATFORM ─────────────────────────────────────────────────────

GCP_PROJECT_ID=
GCP_REGION=northamerica-northeast1


# ── OBSERVABILITY (OPTIONAL) ──────────────────────────────────────────────────
# Leave blank to silently drop traces. Set to a Grafana/Honeycomb OTLP endpoint to enable.

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=autodidact


# ── PROVIDER SELECTION ────────────────────────────────────────────────────────
# Production overrides live in GCP Secret Manager — no changes needed here for local dev.
# CHECKPOINTER must be "postgres" in production (set via autodidact-checkpointer secret).

# Options: openai | anthropic
LLM_PROVIDER=openai
# Options: openai | cohere
EMBEDDING_PROVIDER=openai
# Options: bullmq
QUEUE_PROVIDER=bullmq
# Options: supabase
AUTH_PROVIDER=supabase
# Options: memory | postgres
CHECKPOINTER=memory


# ── INTER-SERVICE URLS (LOCAL DEV) ────────────────────────────────────────────

AGENT_SERVICE_URL=http://localhost:3001
API_PORT=3000
AGENT_PORT=3001
WORKER_PORT=3002
