# ─── Database ────────────────────────────────────────────────────────────────
# Default local development URL for Docker Postgres.
# setup.sh copies this file to .env.dev.
DATABASE_URL=postgresql://postgres:password@localhost:5432/autodidact
#
# Production example: use the Supabase transaction-mode pooler URL (port 6543).
# This is required for WSL2 and recommended generally.
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres
#
# Optional: keep the direct URL for environments with IPv6 (cloud, native Linux)
DATABASE_URL_DIRECT=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
# Publishable key — safe for client use; configure in apps/mobile/app.json → extra.supabasePublishableKey
SUPABASE_PUBLISHABLE_KEY=
# Secret key — server-side admin client (packages/db) only; never expose to clients
SUPABASE_SECRET_KEY=
# No JWT secret needed — the API verifies tokens locally via Supabase's public JWKS endpoint

# ─── LLM / Embeddings ────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Optional: Anthropic as alternative LLM provider
ANTHROPIC_API_KEY=

# ─── Provider selection (swap without code changes) ──────────────────────────
# Options: openai | anthropic
LLM_PROVIDER=openai
# Options: openai | cohere
EMBEDDING_PROVIDER=openai
# Options: bullmq
QUEUE_PROVIDER=bullmq
# Options: supabase
AUTH_PROVIDER=supabase
# Options: memory | postgres
CHECKPOINTER=memory

# ─── Inter-service ────────────────────────────────────────────────────────────
AGENT_SERVICE_URL=http://localhost:3001
API_PORT=3000
AGENT_PORT=3001
WORKER_PORT=3002

# ─── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=autodidact

# ─── GCP (CI/CD + infra) ─────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
